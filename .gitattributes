# Normalize line endings: LF in the repo, matching CI (Ubuntu).
* text=auto eol=lf

# Explicit text types
*.php   text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.neon  text eol=lf
*.dist  text eol=lf
*.xml   text eol=lf

# Binary assets (never normalize)
*.png binary
*.jpg binary
*.jpeg binary
